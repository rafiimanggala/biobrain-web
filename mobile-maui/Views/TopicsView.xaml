<?xml version="1.0" encoding="utf-8"?>

<views:BasePurchaseView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                        xmlns:layoutControls="clr-namespace:CustomControls.LayoutControls;assembly=BioBrain"
                        xmlns:appResources="clr-namespace:BioBrain.AppResources;assembly=BioBrain"
                        xmlns:customControls="clr-namespace:CustomControls;assembly=BioBrain"
                        xmlns:views="clr-namespace:BioBrain.Views;assembly=BioBrain"
                        xmlns:controls="clr-namespace:BioBrain.Controls;assembly=BioBrain"
                        xmlns:common="clr-namespace:Common;assembly=BioBrain"
                        x:Class="BioBrain.Views.TopicsView" x:Name="This">

    <Grid>
        <StackLayout Style="{StaticResource MainContainerStyle}" HorizontalOptions="FillAndExpand">
            <!--Header-->
            <controls:TopBaner Text="{Binding AreaOfStudyName}"  Navigating="BottomBar_OnNavigating" Share="TopBaner_OnShare"/>

            <!--Body-->
            <StackLayout BackgroundColor="{x:Static customControls:CustomColors.LightMain}"
                         HorizontalOptions="FillAndExpand"
                         VerticalOptions="FillAndExpand">
                <ListView CachingStrategy="RecycleElement" x:Name="TopicsList" ItemsSource="{Binding Topics}"
                          ItemTapped="Button_OnClicked"
                          SeparatorVisibility="None" HasUnevenRows="True" HorizontalOptions="FillAndExpand">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <ViewCell.View>
                                    <Grid HorizontalOptions="FillAndExpand">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Style="{StaticResource ListImageStyle}"
                                               Source="{Binding DarkIconPath}"
                                               HorizontalOptions="Start" VerticalOptions="CenterAndExpand" />
                                        <Label Grid.Column="1" Text="{Binding Name}"
                                               Style="{StaticResource ListViewLabelStyle}"
                                               LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand" />
                                        <!--<Label Grid.Column="2" Text="{Binding CompletionString}"
                                               HorizontalOptions="End" HorizontalTextAlignment="End" Margin="5,5,15,5"
                                               VerticalOptions="CenterAndExpand" VerticalTextAlignment="Center"
                                               LineBreakMode="NoWrap"
                                               TextColor="{StaticResource IceBlue}" FontSize="14" FontAttributes="Bold"
                                               FontFamily="Nunito" />-->
                                    </Grid>
                                </ViewCell.View>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackLayout>

            <!--Footer-->
            <controls:BottomBar CurrentMenyItem="{Binding Source={x:Reference This}, Path=MenuItem}" IsPeriodicTableVisible="{x:Static common:Settings.IsPeriodicTableVisible}"
                                Navigating="BottomBar_OnNavigating"></controls:BottomBar>

        </StackLayout>

        <!--Popup-->
        <layoutControls:ShareButtonsPoup x:Name="Popup" HorizontalOptions="FillAndExpand"
                                         VerticalOptions="EndAndExpand" HeightRequest="60" IsVisible="False"
                                         Margin="10,70"
                                         Link="{Binding Source={x:Static appResources:Links.ShareLink}}"
                                         Text="{appResources:Translate TextToShare}" />

    </Grid>

</views:BasePurchaseView>