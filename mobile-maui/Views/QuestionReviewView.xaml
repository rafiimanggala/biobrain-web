<?xml version="1.0" encoding="utf-8" ?>
<views:BaseView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:layoutControls="clr-namespace:CustomControls.LayoutControls;assembly=BioBrain"
             xmlns:buttons="clr-namespace:CustomControls.Buttons;assembly=BioBrain"
             xmlns:customControls="clr-namespace:CustomControls;assembly=BioBrain"
             xmlns:controls="clr-namespace:BioBrain.Controls;assembly=BioBrain"
             xmlns:common="clr-namespace:Common;assembly=BioBrain"
             xmlns:appResources="clr-namespace:BioBrain.AppResources;assembly=BioBrain"
             xmlns:views="clr-namespace:BioBrain.Views;assembly=BioBrain"
             x:Class="BioBrain.Views.QuestionReviewView" x:Name="This">
    <Grid VerticalOptions="FillAndExpand">
    <StackLayout x:Name="MainStack" Style="{StaticResource MainContainerStyle}" BackgroundColor="White" VerticalOptions="FillAndExpand">

      <!--Header-->
      <controls:TopBaner Text="{Binding TopicName}" Share="TopBaner_OnShare"/>

            <StackLayout Orientation="Vertical" BackgroundColor="{x:Static customControls:CustomColors.LightMain}" Spacing="0" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
        <buttons:HexagonButton FillColor="{Binding HexagonColor}" FontColor="{StaticResource IceBlue}" FontSize="15" HeightRequest="48" MinimumHeightRequest="48" WidthRequest="42" 
                                      Text="{Binding QuestionHeader}" HorizontalOptions="Start" VerticalOptions="Start" Margin="15, 10" IsAnimated="False" BorderThickness="0"/>
        <WebView x:Name="QuestionWebView" Source="{Binding FilePath}" VerticalOptions="FillAndExpand" Navigating="WebView_OnNavigating"/>
      </StackLayout>

            <!--Footer-->
        <controls:BottomBar CurrentMenyItem="{Binding Source={x:Reference This}, Path=MenuItem}" IsPeriodicTableVisible="{x:Static common:Settings.IsPeriodicTableVisible}" ></controls:BottomBar>

        </StackLayout>

      <!--Popup-->
      <layoutControls:ShareButtonsPoup x:Name="SharePopup" HorizontalOptions="FillAndExpand" VerticalOptions="EndAndExpand" HeightRequest="60" 
                                       IsVisible="False" Margin="10,70" Link="{Binding Source={x:Static appResources:Links.ShareLink}}" 
                                       Text="{appResources:Translate TextToShare}"/>


        <layoutControls:PopupWebView x:Name="Popup" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" Margin="5, 170" ContentChaging="PopupWebView_OnContentChaging"
                                 Closed="Popup_OnClosed" MaxWidth="500" MaxHeight="350"/>
  </Grid>
</views:BaseView>