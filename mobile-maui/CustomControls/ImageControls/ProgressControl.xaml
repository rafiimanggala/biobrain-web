<?xml version="1.0" encoding="UTF-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="CustomControls.ImageControls.ProgressControl">
  <ContentView.Content>
    <StackLayout Orientation="Horizontal" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
      <Image x:Name="SymbolImage" HorizontalOptions="Start" VerticalOptions="CenterAndExpand" HeightRequest="16" WidthRequest="16" Margin="20,0,0,0"/>
      <Label Style="{StaticResource ProgressLabelStyle}" x:Name="ValueLabel"/>
    </StackLayout>
  </ContentView.Content>
</ContentView>
