<?xml version="1.0" encoding="UTF-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:customControls="clr-namespace:CustomControls;assembly=BioBrain"
             x:Class="CustomControls.LayoutControls.MaterialDropDown">
    <ContentView.Content>
        <StackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Orientation="Vertical" Spacing="0">
            <Label x:Name="PlaceholderLabel" FontSize="9" Opacity="0" TextColor="{x:Static customControls:CustomColors.GrayColor}" IsVisible="False" VerticalOptions="Start"/>
            <StackLayout Orientation="Horizontal" Spacing="0" Margin="0">
                <Image x:Name="PrefixImage" HeightRequest="26" WidthRequest="26" IsVisible="False" Margin="3"/>
                <Picker x:Name="TextEntry" HorizontalOptions="Fill" VerticalOptions="Fill" BackgroundColor="Transparent"
                        TextColor="{x:Static customControls:CustomColors.GrayColor}"
                        SelectedIndexChanged="TextEntry_OnSelectedIndexChanged"
                        Focused="PlaceholderLabel_OnFocused"
                        Unfocused="PlaceholderLabel_OnUnfocused"
                        FontAttributes="Italic"/>
            </StackLayout>
            <BoxView x:Name="Underline" HorizontalOptions="Fill" Color="{x:Static customControls:CustomColors.GrayColor}" HeightRequest="1"/>
            <Label x:Name="Error" TextColor="Red" FontSize="9" Margin="0,1" Opacity="0"/>
        </StackLayout>
    </ContentView.Content>
</ContentView>
