<?xml version="1.0" encoding="UTF-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CustomControls.LayoutControls.TopBaner">
    <ContentView.Content>
        <StackLayout Style="{StaticResource HeaderStyle}">
            <Image x:Name="EmblemImage" Style="{StaticResource HeaderImageStyle}" HorizontalOptions="Start">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="EmblemImage_OnTapped"/>
                </Image.GestureRecognizers>
            </Image>
            <Label x:Name="HeaderLabel" Style="{StaticResource HeaderLabelStyle}" FontSize="20"/>
            <Image x:Name="AboutButton" Style="{StaticResource HeaderImageStyle}" Source="abouticon.png" HorizontalOptions="End">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="AboutButton_OnTapped"/>
                </Image.GestureRecognizers>
            </Image>
        </StackLayout>
    </ContentView.Content>
</ContentView>
