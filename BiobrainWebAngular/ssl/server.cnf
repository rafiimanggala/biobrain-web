[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
C = RU
ST = Tomsk
L = Tomsk
O = Andapex
OU = Andapex
emailAddress = support@andapex.com
CN = Angular development certificate

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = localhost